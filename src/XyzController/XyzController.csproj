<?xml version="1.0" encoding="utf-8"?>
<!-- 主项目：XyzController WinForms 应用。
     引用 XyzController.Controls 类库（包含 XYView / ZBarView 自定义控件）。 -->
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <AssemblyName>XyzController</AssemblyName>
    <RootNamespace>XyzController</RootNamespace>
    <TargetFrameworkVersion>v4.6.1</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <Deterministic>true</Deterministic>
    <LangVersion>latest</LangVersion>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{A1B2C3D4-E5F6-4789-ABCD-1234567890AB}</ProjectGuid>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <WarningLevel>2</WarningLevel>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup>
    <StartupObject />
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>
  <!-- 引用本解决方案内的控件类库项目 -->
  <ItemGroup>
    <ProjectReference Include="..\XyzController.Controls\XyzController.Controls.csproj">
      <Project>{b1c4d7e2-3f6a-4b8c-9d1e-2a5f7b9c8d33}</Project>
      <Name>XyzController.Controls</Name>
    </ProjectReference>
    <!-- 引用 WPF 宿主接口 DLL：Program.Main 通过 WpfHostLauncher.Run(new MainForm()) 启动。
         依赖方向单向（XyzController → WpfHost），WpfHost 不引用本项目，无循环引用。 -->
    <ProjectReference Include="..\XyzController.WpfHost\XyzController.WpfHost.csproj">
      <Project>{D453FED7-6A20-493D-BFC4-C3CFB6479A8C}</Project>
      <Name>XyzController.WpfHost</Name>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="MainForm.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Include="MainForm.Designer.cs">
      <DependentUpon>MainForm.cs</DependentUpon>
    </Compile>
    <Compile Include="Logic\AxisController.cs" />
    <Compile Include="Logic\XyzControllerHub.cs" />
    <Compile Include="Logic\JogMode.cs" />
    <Compile Include="Logic\AxisJogService.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="MainForm.resx">
      <DependentUpon>MainForm.cs</DependentUpon>
    </EmbeddedResource>
  </ItemGroup>
  <!-- 必需：引入 C# 构建目标。老式（非 SDK 风格）的 .csproj 不会自动加载。 -->
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Target Name="BeforeBuild" />
  <Target Name="AfterBuild" />
</Project>