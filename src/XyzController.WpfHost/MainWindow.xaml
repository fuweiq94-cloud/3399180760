<!-- 说明：窗口采用固定尺寸（SizeToContent="Manual"），启动后绝不因页面
     内容改变大小；切换页面只切 Visibility，窗口尺寸始终保持一致。
     所有页面统一 Dock=Fill 填充同一内容区，靠自身的 Dock/Anchor 弹性
     布局与 AutoScroll 适配窗口（页面适应窗口，而非窗口适应页面）。
     MinWidth/MinHeight 限制用户手动缩放的下限；小屏设备上 Window_Loaded
     会把超出工作区的初始尺寸一次性钳制到屏幕内。 -->
<Window x:Class="XyzController.WpfHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XYZ 轴控制器 · WPF 宿主"
        Width="1500" Height="880"
        MinWidth="1100" MinHeight="680"
        SizeToContent="Manual"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部导航栏 -->
            <RowDefinition Height="Auto" />
            <!-- 页面内容区 -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== 顶部导航栏 ===== -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="8,4">
            <StackPanel x:Name="navBar" Orientation="Horizontal" />
        </Border>

        <!-- ===== 页面内容区 ===== -->
        <!-- 注意：不要在此区域上方放置任何 WPF 元素（Airspace 限制） -->
        <Grid x:Name="contentArea" Grid.Row="1" />
    </Grid>
</Window>
