<!-- 说明：Width/Height/MinWidth/MinHeight 仅为首轮布局用的占位值。
     Window_Loaded 时按全部页面设计尺寸（AutoScale 缩放后的 ClientSize /
     MinimumSize）的并集最大值适配一次并覆盖；之后切换页面窗口尺寸保持
     稳定不再变化，业务方无需关心。 -->
<Window x:Class="XyzController.WpfHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XYZ 轴控制器 · WPF 宿主"
        Height="750" Width="1280"
        MinWidth="900" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Closed="Window_Closed">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 顶部导航栏 -->
            <RowDefinition Height="Auto" />
            <!-- 页面内容区 -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ===== 顶部导航栏 ===== -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="8,4">
            <StackPanel x:Name="navBar" Orientation="Horizontal" />
        </Border>

        <!-- ===== 页面内容区 ===== -->
        <!-- 注意：不要在此区域上方放置任何 WPF 元素（Airspace 限制） -->
        <Grid x:Name="contentArea" Grid.Row="1" />
    </Grid>
</Window>
