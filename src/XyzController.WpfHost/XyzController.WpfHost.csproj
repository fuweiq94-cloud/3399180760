<?xml version="1.0" encoding="utf-8"?>
<!-- WPF 宿主项目：同时生成 DLL 和 EXE 两种输出。
     DLL（主输出）：对外提供 WpfHostLauncher.Run(Form) 标准接口，供 XyzController 等项目调用。
     EXE（后置构建）：独立外部程序，通过反射加载 XyzController.dll 中的 MainForm 运行。
     本项目不直接引用任何业务项目（避免循环依赖），仅依赖 .NET 框架程序集。 -->
<Project ToolsVersion="14.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{D453FED7-6A20-493D-BFC4-C3CFB6479A8C}</ProjectGuid>
    <OutputType>Library</OutputType>
    <RootNamespace>XyzController.WpfHost</RootNamespace>
    <AssemblyName>XyzController.WpfHost</AssemblyName>
    <TargetFrameworkVersion>v4.6.1</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <ProjectTypeGuids>{60dc8134-eba5-43b8-bcc9-bb4bc16c2548};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <WarningLevel>4</WarningLevel>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <Deterministic>true</Deterministic>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <!-- 框架程序集引用：WinForms、WPF 及互操作桥接 -->
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Data" />
    <Reference Include="System.Drawing" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="WindowsFormsIntegration" />
    <Reference Include="System.Xaml" />
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="WindowsBase" />
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>
  <!-- WPF 页面（类库无 App.xaml，WPF Application 由 WpfHostLauncher 在代码中按需创建） -->
  <ItemGroup>
    <Page Include="MainWindow.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>
  <!-- 编译项 -->
  <ItemGroup>
    <Compile Include="MainWindow.xaml.cs">
      <DependentUpon>MainWindow.xaml</DependentUpon>
    </Compile>
    <Compile Include="WpfHostLauncher.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <!-- 注意：Bootstrapper.cs 不参与本项目编译，仅由 BuildExe 后置目标单独编译为 EXE -->
  <!-- 必需：C# 构建目标 + WPF 构建目标（老式非 SDK 风格需显式导入） -->
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Target Name="BeforeBuild" />
  <Target Name="AfterBuild" />
  <!-- 后置构建目标：将 Bootstrapper.cs 编译为独立 EXE（引用本项目生成的 DLL）。
       EXE 通过反射加载 XyzController.dll 创建 MainForm，无编译时依赖。 -->
  <Target Name="BuildExe" AfterTargets="Build">
    <Csc Sources="$(MSBuildProjectDirectory)\Bootstrapper.cs"
         References="@(ReferencePath);$(TargetPath)"
         OutputAssembly="$(TargetDir)$(AssemblyName).exe"
         TargetType="winexe"
         LangVersion="latest"
         EmitDebugInformation="$(DebugSymbols)" />
    <Message Importance="high" Text="已生成独立 EXE → $(TargetDir)$(AssemblyName).exe" />
  </Target>
</Project>
